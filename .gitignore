# Env
.env
.env.local

# Data (never commit raw or processed; only schemas and READMEs)
data/raw/
data/processed/
data/external/
data/cache/
!data/README.md

# Reports/figures generated locally
reports/figures/*.png
reports/figures/*.pdf
reports/figures/*.svg
!reports/figures/.gitkeep

# Regenerable diagnostic data (the markdown summary stays in git)
reports/diagnostics/*.parquet
reports/diagnostics/*.csv

# OS
.DS_Store
Thumbs.db
desktop.ini

# IDE
.idea/
.vscode/
*.swp

# Claude Code local settings (project-wide settings.json IS committed if used)
.claude/settings.local.json

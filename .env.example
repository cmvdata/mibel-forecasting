# ESIOS API token (https://api.esios.ree.es). Required only for the loader
# validation test that pulls a sample of indicator 600 to cross-check the
# pre-computed v8 dataset. Modelling itself does not hit the API.
ESIOS_API_TOKEN=

# Paths to the consolidated parquet datasets reused from mibel-congestion-monitor.
# Override these in .env if your local copies live elsewhere.
MIBEL_DAM_PARQUET=C:/Users/Carlo/Desktop/Projects/mibel-congestion-monitor/data/processed/mibel_dataset_20190101_20241231_v8.parquet
MIBEL_CID_PARQUET=C:/Users/Carlo/Desktop/Projects/mibel-congestion-monitor/neuro_detector/data/processed/features_2022_2024.parquet
